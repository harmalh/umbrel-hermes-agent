#!/bin/bash
set -Eeuo pipefail

mkdir -p "${APP_DATA_DIR}/www" "${APP_DATA_DIR}/data"

if [ ! -f "${APP_DATA_DIR}/www/index.html" ]; then
    cat > "${APP_DATA_DIR}/www/index.html" << 'HTML'
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Hermes Agent on Umbrel</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 44rem; margin: 2rem; line-height: 1.5; color: #1a1a1a; }
    code { background: #f0f0f0; padding: 0.15rem 0.35rem; border-radius: 4px; font-size: 0.9em; }
    h2 { margin-top: 1.75rem; font-size: 1.1rem; }
    a { color: #0b57d0; }
    ul { padding-left: 1.25rem; }
  </style>
</head>
<body>
  <h1>Hermes Agent</h1>
  <p>
    The <strong>gateway</strong> (Telegram, Discord, Slack, WhatsApp, Signal, etc.) runs in the
    <code>hermes</code> container. This page is the Umbrel App Store entry point so you have
    setup instructions in the browser.
  </p>

  <h2>Documentation</h2>
  <ul>
    <li><a href="https://hermes-agent.nousresearch.com/docs/user-guide/docker/">Docker &amp; gateway</a></li>
    <li><a href="https://hermes-agent.nousresearch.com/docs/user-guide/configuration/">Configuration</a></li>
    <li><a href="https://hermes-agent.nousresearch.com/docs/user-guide/messaging/">Messaging gateway</a></li>
  </ul>

  <h2>First-time setup</h2>
  <p>
    Hermes stores secrets and config under <code>APP_DATA_DIR/data</code> on your Umbrel
    (mounted as <code>/opt/data</code> in the container): <code>.env</code>, <code>config.yaml</code>, etc.
  </p>
  <ul>
    <li>
      <strong>Interactive wizard:</strong> Umbrel <strong>Settings → Advanced → Terminal</strong>, then run<br/>
      <code>docker exec -it hermes-agent_hermes_1 bash</code><br/>
      and <code>hermes setup</code> (or follow the upstream quick start).
    </li>
    <li>
      <strong>Manual:</strong> Edit <code>.env</code> / <code>config.yaml</code> on the host inside this app&rsquo;s data folder
      (SSH or file share), then restart the app from the Umbrel UI.
    </li>
  </ul>

  <h2>Logs &amp; health</h2>
  <ul>
    <li>Umbrel app <strong>⋮</strong> menu → logs for this app, or Terminal → <code>docker logs hermes-agent_hermes_1</code></li>
    <li>Upstream suggests <code>docker exec &lt;container&gt; hermes version</code> to verify the binary.</li>
  </ul>

  <h2>Upstream</h2>
  <p>
    <a href="https://github.com/NousResearch/hermes-agent">NousResearch/hermes-agent</a>
    · Packaging: <a href="https://github.com/harmalh/umbrel-hermes-agent">harmalh/umbrel-hermes-agent</a>
  </p>
</body>
</html>
HTML
fi
